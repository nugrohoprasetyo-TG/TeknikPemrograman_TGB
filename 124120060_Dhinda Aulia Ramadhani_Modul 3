
def c_to_f(c): 
    return (c * 9/5) + 32

def f_to_c(f): 
    return (f - 32) * 5/9


import konversi_3

c = float(input("Masukkan suhu Celcius: "))
print("Suhu dalam Fahrenheit =",konversi_3.c_to_f(c))

f = float(input("Masukkan suhu Fahrenheit: "))
print("Suhu dalam Celcius =",konversi_3.f_to_c(f))

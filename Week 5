class Survey(ABC):
    """
    Class abstrak untuk survey geofisika
    """
    def __init__(self, nama_survey):
        self.nama_survey = nama_survey

    @abstractmethod
    def processing(self):
        pass


class SeismicSurvey(Survey):
    def processing(self):
        print(f"{self.nama_survey} → Processing: Band-pass filtering & stacking")


class GravitySurvey(Survey):
    def processing(self):
        print(f"{self.nama_survey} → Processing: Upward continuation & Bouguer correction")


class MagnetikSurvey(Survey):
    def processing(self):
        print(f"{self.nama_survey} → Processing: RTP & anomaly mapping")


# =====================================================
# CONTOH PENGGUNAAN CHALLENGE 2
# =====================================================

survey_list = [
    SeismicSurvey("Survey Seismik Cekungan A"),
    GravitySurvey("Survey Gravitasi Area Vulkanik"),
    MagnetikSurvey("Survey Magnetik Regional")
]

print("\n" + "=" * 60)
print("PROSES DATA SURVEY".center(60))
print("=" * 60)

for survey in survey_list:
    survey.processing()

print("\n" + "=" * 60)
print("SEMUA PROSES SURVEY SELESAI".center(60))
print("=" * 60)

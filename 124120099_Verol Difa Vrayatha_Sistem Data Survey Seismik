# Data Awal
survey = {
    "Survey_A": [
        {"trace_id": 1, "receiver": "R1", "offset": 100, "QC_flag": "OK"},
        {"trace_id": 2, "receiver": "R2", "offset": 150, "QC_flag": "OK"},
        {"trace_id": 3, "receiver": "R3", "offset": 200, "QC_flag": "BAD"}
    ],
    "Survey_B": [
        {"trace_id": 4, "receiver": "R1", "offset": 120, "QC_flag": "OK"},
        {"trace_id": 5, "receiver": "R4", "offset": 250, "QC_flag": "OK"},
        {"trace_id": 6, "receiver": "R2", "offset": 300, "QC_flag": "BAD"}
    ],
    "Survey_C": [
        {"trace_id": 7, "receiver": "R5", "offset": 180, "QC_flag": "OK"}
    ]
}

trace_bad = []
for survey_name, daftar_trace in survey.items():
    for trace in daftar_trace:
        if trace["QC_flag"] == "BAD":
            trace_bad.append(trace["trace_id"])
print("Trace BAD:", trace_bad)

total_trace = sum(len(daftar_trace) for daftar_trace in survey.values())
print("Total trace:", total_trace)

survey_terbanyak = max(survey, key=lambda s: len(survey[s]))
print("Survey dengan trace terbanyak:", survey_terbanyak, "(", len(survey[survey_terbanyak]), "trace )")

receiver_unik = set()
for daftar_trace in survey.values():
    for trace in daftar_trace:
        receiver_unik.add(trace["receiver"])
print("Receiver unik:", receiver_unik)

jumlah_receiver = {}
for daftar_trace in survey.values():    
    for trace in daftar_trace:
        r = trace["receiver"]
        jumlah_receiver[r] = jumlah_receiver.get(r, 0) + 1
print("Jumlah trace per receiver:", jumlah_receiver)


from abc import ABC, abstractmethod

# 1. Buat class abstrak Survey
class Survey(ABC):
    @abstractmethod
    def processing(self):
        pass

# 2. Turunkan SeismicSurvey, GravitySurvey, MagnetikSurvey
class SeismicSurvey(Survey):
    def processing(self):
        print("SeismicSurvey: Melakukan filtering sinyal seismik...")

class GravitySurvey(Survey):
    def processing(self):
        print("GravitySurvey: Melakukan upward continuation dan anomaly mapping...")

class MagnetikSurvey(Survey):
    def processing(self):
        print("MagnetikSurvey: Melakukan filtering medan magnet...")

# 4. Masukkan objek ke dalam list dan iterasi
if _name_ == "_main_":
    surveys = [SeismicSurvey(), GravitySurvey(), MagnetikSurvey()]
    for s in surveys:
        s.processing()
